# ================================================================
# ImageTalk — end-user settings
#
# Copy this file to ".settings.env" and edit as needed.
# You MUST set IMAGETALK_ROOT. Other values have sensible defaults.
# ================================================================

# --- Required ----------------------------------------------------

# Absolute path to the folder containing the images you want to search.
# Mounted read-only into the backend container.
# Windows example:  IMAGETALK_ROOT=C:\Users\YourName\Pictures
IMAGETALK_ROOT=

# --- Image version (pin to a specific tag if needed) -------------

IMAGETALK_VERSION=latest

# --- Ports (change only if these collide with something else) ----

FRONTEND_PORT=2080
BACKEND_PORT=8000

# --- Postgres ----------------------------------------------------
#
# NOTE: These values are used when Postgres initializes its data
# directory on the very first start. Changing them later will NOT
# re-apply — you would have to delete ./data/postgres to reset.

POSTGRES_USERNAME=imagetalk
POSTGRES_PASSWORD=imagetalk
POSTGRES_DATABASE=imagetalk

# --- Qdrant ------------------------------------------------------

QDRANT_COLLECTION_NAME=images

# --- Ollama models (pulled by scripts/install.bat) ---------------

EMBEDDING_MODEL=qwen3-embedding:8b
EMBEDDING_CONTEXT=24576
EMBEDDING_DIMENSION=4096

DESCRIBE_MODEL=gemma3:27b-it-qat
DESCRIBE_CONTEXT=24576
DESCRIBE_TEMPERATURE=0.0

TALKING_MODEL=gemma3:12b
TALKING_CONTEXT=24576
TALKING_TEMPERATURE=0.3

OLLAMA_TIMEOUT=60

# --- Misc --------------------------------------------------------

IMAGE_EXTENSIONS=jpg,jpeg,png,gif,bmp,webp,tiff,tif,heic,heif
LOG_LEVEL=INFO
